{
  "name": "meu-chat-local",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "lint": "eslint \"apps/api/src/**/*.js\" \"modules/**/*.js\" \"platform/**/*.js\" \"shared/**/*.js\" \"apps/web/script.js\"",
    "format": "prettier --write \"**/*.{js,mjs,json,md,yml,yaml,html,css}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,json,md,yml,yaml,html,css}\"",
    "test:ops:canary": "node --test ops/scripts/local/release-canary.test.mjs",
    "test:ops:runbooks": "node --test ops/scripts/local/runbook-suggestions.test.mjs",
    "smoke:test": "node ops/scripts/local/smoke-test.mjs",
    "smoke:full": "npm run smoke:test && npm run verify:health",
    "verify:health": "bash ops/scripts/local/verify-health.sh",
    "verify:routes": "bash ops/scripts/local/verify-routes.sh",
    "release:local": "npm run build && npm run smoke:full && npm run verify:routes",
    "incident:runbook": "bash ops/scripts/local/runbook-incident.sh",
    "dr:test": "bash ops/scripts/local/disaster-recovery-test.sh",
    "release:canary": "node ops/scripts/local/release-canary.mjs",
    "capacity:profile": "node ops/scripts/local/capacity-profile.mjs",
    "dist:package": "bash ops/scripts/local/package-dist.sh",
    "dist:install": "bash ops/scripts/local/install.sh",
    "dist:start": "bash ops/scripts/local/start.sh",
    "dist:stop": "bash ops/scripts/local/stop.sh",
    "dist:uninstall": "bash ops/scripts/local/uninstall.sh",
    "skill:validate": "node scripts/skill-validator.mjs",
    "skill:validate:strict": "node scripts/skill-validator.mjs --strict",
    "skill:validate:json": "node scripts/skill-validator.mjs --json",
    "skill:validate:strict:json": "node scripts/skill-validator.mjs --strict --json",
    "skill:validate:strict:json:compact": "node scripts/skill-validator.mjs --strict --json --pretty false",
    "test:skills:validator": "node --test scripts/skill-validator.test.mjs",
    "test:skills:schema-note": "node --test scripts/skill-validator-schema-note.test.mjs",
    "test:skills:enforcement-status": "node --test scripts/skill-schema-enforcement-status.test.mjs",
    "test:skills:governance-preflight": "node --test scripts/skill-governance-preflight.test.mjs",
    "skill:schema-note": "node scripts/skill-validator-schema-note.mjs",
    "skill:schema-enforcement:status": "node scripts/skill-schema-enforcement-status.mjs",
    "skill:governance:preflight": "node scripts/skill-governance-preflight.mjs",
    "skill:governance:preflight:strict-io": "node scripts/skill-governance-preflight.mjs --strict-io --artifacts-dir artifacts",
    "skill:governance:preflight:inspect": "node scripts/skill-governance-preflight.mjs --dry-run --json --strict-io --artifacts-dir artifacts",
    "skill:governance:preflight:inspect:summary": "node scripts/skill-governance-preflight.mjs --dry-run --strict-io --artifacts-dir artifacts",
    "skill:governance:preflight:inspect:ci": "node scripts/skill-governance-preflight.mjs --dry-run --json --strict-io --artifacts-dir artifacts --confidence-profile ci",
    "dev": "npm run dev --workspace apps/web",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:web:strict": "npm run dev:strict --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:all": "concurrently -k -n API,WEB -c green,cyan \"npm run dev:api\" \"npm run dev:web\"",
    "dev:all:strict": "concurrently -k -n API,WEB -c green,cyan \"npm run dev:api\" \"npm run dev:web:strict\"",
    "dev:start": "npm run dev:doctor -- --skip-endpoints && npm run dev:all:clean",
    "dev:start:strict": "npm run dev:doctor:strict -- --skip-endpoints && npm run dev:all:clean",
    "dev:smoke": "bash ops/scripts/local/dev-smoke.sh",
    "dev:smoke:strict": "bash ops/scripts/local/dev-smoke.sh --strict",
    "dev:menu": "bash ops/scripts/local/dev-menu.sh",
    "dev:open": "bash ops/scripts/local/dev-open.sh",
    "dev:url": "bash ops/scripts/local/dev-open.sh --no-open",
    "dev:status": "bash ops/scripts/local/dev-status.sh",
    "dev:logs": "bash ops/scripts/local/dev-logs.sh latest",
    "dev:logs:list": "bash ops/scripts/local/dev-logs.sh list",
    "dev:logs:follow": "bash ops/scripts/local/dev-logs.sh follow",
    "dev:stop": "bash ops/scripts/local/dev-stop.sh",
    "dev:restart": "npm run dev:stop && npm run dev:start",
    "dev:doctor": "bash ops/scripts/local/dev-doctor.sh",
    "dev:doctor:strict": "bash ops/scripts/local/dev-doctor.sh --strict",
    "dev:ports:status": "bash ops/scripts/local/clean-dev-ports.sh status",
    "dev:ports:doctor": "bash ops/scripts/local/clean-dev-ports.sh doctor",
    "dev:ports:clean": "bash ops/scripts/local/clean-dev-ports.sh",
    "dev:all:clean": "npm run dev:ports:clean && npm run dev:all:strict",
    "build": "npm run build --workspace apps/web",
    "preview": "npm run preview --workspace apps/web",
    "build:all": "npm run build --workspace apps/web",
    "preview:all": "concurrently -k -n API,PREVIEW -c green,magenta \"npm run dev:api\" \"npm run preview --workspace apps/web\"",
    "verify:consolidation": "npm run test --workspace apps/web -- tests/phase4-route-integration.test.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.3"
  }
}
