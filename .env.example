# Exemplo de configuração multiplataforma
# Copie este arquivo para .env.local, .env.production, etc. conforme o ambiente
NODE_ENV=development
PORT=4000
# Adicione outras variáveis conforme necessário
# Configurações de Rede

# Integração IA
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=llama3

# Modo Desktop (Lifecycle Orchestration)
# Se true: inicia o "ollama serve" automaticamente e abre o browser ao subir o servidor.
# Ao encerrar (Ctrl+C), o sistema desliga o Ollama e fecha o SQLite com segurança.
# Mantenha false (ou remova) em ambientes Docker/CI/Servidor.
DESKTOP_MODE=false